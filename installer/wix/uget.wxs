<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" 
           Name="uget" 
           Language="1033" 
           Version="1.0.0" 
           Manufacturer="uget Project" 
           UpgradeCode="12345678-1234-1234-1234-123456789012">
    
    <Package InstallerVersion="405" 
             Compressed="yes" 
             InstallScope="perMachine" 
             Description="uget - User-friendly wrapper for Windows Package Manager"
             Comments="Enhanced interface for winget package management"
             Manufacturer="uget Project" />

    <!-- Support silent installation -->
    <Property Id="MSIUSEREALADMINDETECTION" Value="1" />
    <Property Id="REINSTALLMODE" Value="amus" />
    
    <!-- Add to PATH by default, but allow user to opt out -->
    <Property Id="ADDTOPATH" Value="1" />
    
    <!-- Upgrade configuration -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <!-- Media configuration -->
    <MediaTemplate EmbedCab="yes" />

    <!-- Feature configuration -->
    <Feature Id="ProductFeature" Title="uget" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PathComponent" />
    </Feature>

    <!-- UI for interactive installation -->
    <UIRef Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    
    <!-- Skip license dialog for silent installation -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch uget help" />
    <!-- Removed custom action for now to fix build issues -->

  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="uget" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="uget" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- Main executable component -->
      <Component Id="ProductComponent" Guid="12345678-1234-1234-1234-123456789013">
        <File Id="uget.exe" Source="installer\wix\uget.exe" KeyPath="yes" />
        <RegistryValue Root="HKCU" 
                       Key="Software\uget" 
                       Name="installed" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="no" />
      </Component>

      <!-- Shortcuts component -->
      <Component Id="ShortcutComponent" Guid="12345678-1234-1234-1234-123456789015">
        <RegistryValue Root="HKCU" 
                       Key="Software\uget" 
                       Name="shortcuts" 
                       Type="integer" 
                       Value="1" 
                       KeyPath="yes" />
        <Shortcut Id="ApplicationStartMenuShortcut" 
                  Directory="ApplicationProgramsFolder" 
                  Name="uget Command Prompt"
                  Target="[INSTALLFOLDER]uget.exe"
                  Arguments="--help"
                  Description="Enhanced Windows Package Manager interface"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="ApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      </Component>
    </ComponentGroup>
    
    <!-- Component for PATH manipulation -->
    <Component Id="PathComponent" Directory="INSTALLFOLDER" Guid="12345678-1234-1234-1234-123456789014">
      <Condition>ADDTOPATH=1</Condition>
      <CreateFolder />
      <Environment Id="PathEnvironment" 
                   Name="PATH" 
                   Value="[INSTALLFOLDER]" 
                   Permanent="no" 
                   Part="last" 
                   Action="set" 
                   System="yes" />
    </Component>
  </Fragment>
</Wix>
